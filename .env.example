# ============================================
# Amharic Document System - Minimal Config
# For personal local use only
# ============================================

# --------------------------------------------
# AI APIs (REQUIRED)
# --------------------------------------------
# Get free Gemini key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_key_here

# Optional fallback (get $10 free: https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional for Claude API (if not using Desktop app)
ANTHROPIC_API_KEY=your_anthropic_key_here

# --------------------------------------------
# Encryption (Auto-generated, don't change)
# --------------------------------------------
MASTER_ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1

# --------------------------------------------
# Database Passwords (Change if exposing to network)
# --------------------------------------------
# For local use, defaults are fine
POSTGRES_PASSWORD=postgres_pass
MONGODB_PASSWORD=mongo_pass
REDIS_PASSWORD=

# --------------------------------------------
# Optional: External Services
# --------------------------------------------
# Only if you want email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Only if you want Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --------------------------------------------
# That's it! Everything else uses defaults
# --------------------------------------------