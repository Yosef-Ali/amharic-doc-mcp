# Amharic Document System - Frontend Environment Configuration
# Copy this file to .env.local and configure with your actual values

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# API version
VITE_API_VERSION=v1

# WebSocket URL
VITE_WS_URL=ws://localhost:8000

# API timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ============================================================================
# MCP (Model Context Protocol) CONFIGURATION
# ============================================================================
# MCP endpoint
VITE_MCP_ENDPOINT=http://localhost:8000/api/v1/mcp

# MCP WebSocket endpoint
VITE_MCP_WS_ENDPOINT=ws://localhost:8000/api/v1/mcp/ws

# Auto-reconnect WebSocket
VITE_MCP_AUTO_RECONNECT=true

# Reconnect interval (milliseconds)
VITE_MCP_RECONNECT_INTERVAL=5000

# Max reconnect attempts
VITE_MCP_MAX_RECONNECT_ATTEMPTS=10

# ============================================================================
# COPILOTKIT CONFIGURATION
# ============================================================================
# CopilotKit public API key (optional - for cloud features)
VITE_COPILOT_PUBLIC_API_KEY=

# CopilotKit cloud URL (if using cloud version)
VITE_COPILOT_CLOUD_URL=

# Enable CopilotKit features
VITE_ENABLE_COPILOT_CHAT=true
VITE_ENABLE_COPILOT_TEXTAREA=true

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Application name
VITE_APP_NAME=Amharic Document System

# Application version
VITE_APP_VERSION=1.0.0

# Application description
VITE_APP_DESCRIPTION=Comprehensive Amharic Document Preparation System

# Default language (en, am)
VITE_DEFAULT_LANGUAGE=en

# Available languages
VITE_AVAILABLE_LANGUAGES=en,am

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable OCR functionality
VITE_ENABLE_OCR=true

# Enable batch upload
VITE_ENABLE_BATCH_UPLOAD=true

# Enable document export
VITE_ENABLE_EXPORT=true

# Enable search functionality
VITE_ENABLE_SEARCH=true

# Enable advanced search filters
VITE_ENABLE_ADVANCED_SEARCH=true

# Enable document summarization
VITE_ENABLE_SUMMARIZATION=true

# Enable quality metrics display
VITE_ENABLE_QUALITY_METRICS=true

# Enable webhooks management
VITE_ENABLE_WEBHOOKS=true

# Enable dark mode
VITE_ENABLE_DARK_MODE=true

# Enable real-time notifications
VITE_ENABLE_NOTIFICATIONS=true

# Enable document preview
VITE_ENABLE_PREVIEW=true

# ============================================================================
# UPLOAD CONFIGURATION
# ============================================================================
# Maximum file size (bytes) - 100MB
VITE_MAX_FILE_SIZE=104857600

# Allowed file types
VITE_ALLOWED_FILE_TYPES=.pdf,.png,.jpg,.jpeg,.tiff,.bmp,.gif,.docx,.doc,.odt,.csv,.txt,.html,.htm

# Max files per batch upload
VITE_MAX_BATCH_SIZE=10

# Show upload progress
VITE_SHOW_UPLOAD_PROGRESS=true

# Enable drag and drop upload
VITE_ENABLE_DRAG_DROP=true

# ============================================================================
# UI/UX CONFIGURATION
# ============================================================================
# Theme (light, dark, auto)
VITE_THEME=light

# Items per page in lists
VITE_ITEMS_PER_PAGE=20

# Enable animations
VITE_ENABLE_ANIMATIONS=true

# Animation duration (milliseconds)
VITE_ANIMATION_DURATION=300

# Toast notification duration (milliseconds)
VITE_TOAST_DURATION=5000

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================
# Search debounce delay (milliseconds)
VITE_SEARCH_DEBOUNCE=300

# Minimum search query length
VITE_SEARCH_MIN_LENGTH=3

# Max search results per page
VITE_SEARCH_MAX_RESULTS=100

# Enable search suggestions
VITE_ENABLE_SEARCH_SUGGESTIONS=true

# Max search suggestions
VITE_SEARCH_SUGGESTION_LIMIT=10

# Enable search history
VITE_ENABLE_SEARCH_HISTORY=true

# Search history max items
VITE_SEARCH_HISTORY_LIMIT=20

# ============================================================================
# DOCUMENT VIEWER CONFIGURATION
# ============================================================================
# Viewer mode (inline, modal, sidebar)
VITE_VIEWER_MODE=modal

# Enable PDF.js viewer
VITE_ENABLE_PDF_VIEWER=true

# PDF.js worker URL
VITE_PDFJS_WORKER_URL=https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js

# Enable image zoom
VITE_ENABLE_IMAGE_ZOOM=true

# Max zoom level
VITE_MAX_ZOOM_LEVEL=3

# ============================================================================
# EXPORT CONFIGURATION
# ============================================================================
# Available export formats
VITE_EXPORT_FORMATS=pdf,docx,html,markdown,json

# Default export format
VITE_DEFAULT_EXPORT_FORMAT=pdf

# Enable export templates
VITE_ENABLE_EXPORT_TEMPLATES=true

# Export timeout (milliseconds)
VITE_EXPORT_TIMEOUT=60000

# ============================================================================
# PROCESSING STATUS CONFIGURATION
# ============================================================================
# Status polling interval (milliseconds)
VITE_STATUS_POLL_INTERVAL=2000

# Max polling duration (milliseconds) - 30 minutes
VITE_MAX_POLL_DURATION=1800000

# Show detailed processing steps
VITE_SHOW_PROCESSING_STEPS=true

# Enable processing notifications
VITE_ENABLE_PROCESSING_NOTIFICATIONS=true

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
# Token storage key
VITE_AUTH_TOKEN_KEY=auth_token

# Refresh token key
VITE_AUTH_REFRESH_KEY=refresh_token

# Remember me duration (days)
VITE_AUTH_REMEMBER_DURATION=7

# Auto logout on inactivity (milliseconds) - 30 minutes
VITE_AUTH_INACTIVITY_TIMEOUT=1800000

# Enable biometric authentication (if supported)
VITE_ENABLE_BIOMETRIC_AUTH=false

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Enable client-side caching
VITE_ENABLE_CACHE=true

# Cache duration (milliseconds) - 5 minutes
VITE_CACHE_DURATION=300000

# Max cache size (MB)
VITE_MAX_CACHE_SIZE=50

# Cache strategy (memory, localStorage, indexedDB)
VITE_CACHE_STRATEGY=memory

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================
# Google Analytics tracking ID
VITE_GA_TRACKING_ID=

# Enable error tracking (Sentry, etc.)
VITE_ENABLE_ERROR_TRACKING=false

# Sentry DSN
VITE_SENTRY_DSN=

# Sentry environment
VITE_SENTRY_ENVIRONMENT=development

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ============================================================================
# ACCESSIBILITY
# ============================================================================
# Enable keyboard shortcuts
VITE_ENABLE_KEYBOARD_SHORTCUTS=true

# Enable screen reader support
VITE_ENABLE_SCREEN_READER=true

# High contrast mode
VITE_ENABLE_HIGH_CONTRAST=false

# Font size options (small, medium, large)
VITE_DEFAULT_FONT_SIZE=medium

# ============================================================================
# DEVELOPMENT & DEBUG
# ============================================================================
# Enable debug mode
VITE_DEBUG=false

# Show console logs
VITE_SHOW_CONSOLE_LOGS=true

# Enable Redux DevTools
VITE_ENABLE_REDUX_DEVTOOLS=true

# Enable React Query DevTools
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Show API request/response in console
VITE_LOG_API_CALLS=false

# Mock API responses (for development)
VITE_MOCK_API=false

# ============================================================================
# LOCALIZATION
# ============================================================================
# Date format (ISO, US, EU)
VITE_DATE_FORMAT=ISO

# Time format (12h, 24h)
VITE_TIME_FORMAT=24h

# Number format locale
VITE_NUMBER_LOCALE=en-US

# Currency symbol
VITE_CURRENCY_SYMBOL=$

# ============================================================================
# NOTIFICATIONS
# ============================================================================
# Enable browser notifications
VITE_ENABLE_BROWSER_NOTIFICATIONS=true

# Notification position (top-right, top-left, bottom-right, bottom-left)
VITE_NOTIFICATION_POSITION=top-right

# Max concurrent notifications
VITE_MAX_NOTIFICATIONS=3

# Auto-dismiss notifications
VITE_AUTO_DISMISS_NOTIFICATIONS=true

# ============================================================================
# SECURITY
# ============================================================================
# Enable CSRF protection
VITE_ENABLE_CSRF_PROTECTION=true

# Content Security Policy
VITE_CSP_ENABLED=true

# Strict transport security
VITE_ENABLE_HSTS=false

# ============================================================================
# PROGRESSIVE WEB APP (PWA)
# ============================================================================
# Enable PWA features
VITE_ENABLE_PWA=false

# Service worker update interval (milliseconds)
VITE_SW_UPDATE_INTERVAL=3600000

# Enable offline mode
VITE_ENABLE_OFFLINE=false

# ============================================================================
# INTEGRATIONS
# ============================================================================
# Enable third-party integrations
VITE_ENABLE_INTEGRATIONS=false

# Webhook callback URL
VITE_WEBHOOK_CALLBACK_URL=

# ============================================================================
# EXPERIMENTAL FEATURES
# ============================================================================
# Enable experimental features
VITE_ENABLE_EXPERIMENTAL=false

# Enable AI-powered suggestions
VITE_ENABLE_AI_SUGGESTIONS=false

# Enable collaborative editing
VITE_ENABLE_COLLABORATION=false

# Enable version control
VITE_ENABLE_VERSION_CONTROL=false

# ============================================================================
# PRODUCTION OVERRIDES
# ============================================================================
# When building for production, ensure:
# - VITE_API_BASE_URL points to production backend
# - VITE_DEBUG=false
# - VITE_SHOW_CONSOLE_LOGS=false
# - VITE_ENABLE_REDUX_DEVTOOLS=false
# - VITE_ENABLE_REACT_QUERY_DEVTOOLS=false
# - VITE_LOG_API_CALLS=false
# - VITE_MOCK_API=false
# - Analytics and error tracking configured
# - All security features enabled
# - Remove any sensitive test data

# ============================================================================
# ENVIRONMENT-SPECIFIC SETTINGS
# ============================================================================
# These will be automatically set based on the build environment
# NODE_ENV=development|production
# MODE=development|production

# Development-specific
# VITE_DEV_SERVER_PORT=3000
# VITE_DEV_SERVER_HOST=localhost

# Production-specific
# VITE_BUILD_PATH=dist
# VITE_PUBLIC_PATH=/

# ============================================================================
# NOTES
# ============================================================================
# - All VITE_ prefixed variables are exposed to the client
# - Never store secrets or sensitive data in these variables
# - Use .env.local for local overrides (not committed to git)
# - Use .env.production for production builds
# - Restart dev server after changing environment variables
