# Amharic Document System - Backend Environment Configuration
# Copy this file to .env and configure with your actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Amharic Document System
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development  # development, staging, production

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=true  # Set to false in production
WORKERS=4  # Number of worker processes (production only)

# ============================================================================
# DATABASE - PostgreSQL (Relational Data)
# ============================================================================
# Used for: User accounts, processing jobs, metadata, audit logs
DATABASE_URL=postgresql+asyncpg://postgres:postgres_pass@localhost:5432/amharic_doc_system
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false  # Set to true to log all SQL queries (development only)
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600

# ============================================================================
# DATABASE - MongoDB (Document Storage)
# ============================================================================
# Used for: Document content, processing results, large text data
MONGODB_URL=mongodb://admin:mongo_pass@localhost:27017/amharic_documents?authSource=admin
MONGODB_DATABASE=amharic_documents
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# ============================================================================
# CACHE - Redis (Session & Caching)
# ============================================================================
# Used for: Session management, rate limiting, temporary data caching
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_DECODE_RESPONSES=true

# ============================================================================
# OBJECT STORAGE - MinIO/S3 (Binary Files)
# ============================================================================
# Used for: Uploaded documents, exports, processed files
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_pass
MINIO_SECURE=false  # Set to true in production with HTTPS
MINIO_BUCKET_NAME=amharic-documents
MINIO_REGION=us-east-1

# ============================================================================
# SEARCH - Elasticsearch (Full-Text Search)
# ============================================================================
# Used for: Document search, analytics, aggregations
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=amharic_documents
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_TIMEOUT=30
ELASTICSEARCH_MAX_RETRIES=3

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# JWT Settings
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-use-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Password Hashing
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# API Security
API_KEY_HEADER=X-API-Key
ENABLE_API_KEY_AUTH=false  # Enable for service-to-service auth

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]
CORS_MAX_AGE=600

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,tiff,bmp,gif,docx,doc,odt,csv,txt,html,htm,xml
UPLOAD_CHUNK_SIZE=8388608  # 8MB chunks for large uploads
TEMP_UPLOAD_DIR=/tmp/amharic-uploads

# ============================================================================
# OCR CONFIGURATION (Tesseract)
# ============================================================================
TESSERACT_PATH=/usr/bin/tesseract  # Adjust for your system
TESSERACT_LANG=amh+eng  # Languages: amh (Amharic), eng (English)
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/4.00/tessdata

# OCR Processing Settings
OCR_DPI=300  # 300 recommended for best quality
OCR_CONFIDENCE_THRESHOLD=0.6  # Minimum confidence (0.0-1.0)
OCR_PAGE_SEGMENTATION_MODE=3  # PSM mode (3=Fully automatic)
OCR_ENGINE_MODE=1  # OEM mode (1=Neural nets LSTM)
OCR_PREPROCESS_IMAGES=true
OCR_DENOISE=true
OCR_DESKEW=true

# ============================================================================
# CREWAI & AI CONFIGURATION
# ============================================================================
# CrewAI Settings
CREWAI_VERBOSE=true
CREWAI_MAX_ITER=5
CREWAI_MEMORY=true
CREWAI_ALLOW_DELEGATION=true

# OpenAI (Optional - for enhanced AI capabilities)
OPENAI_API_KEY=  # Leave empty if not using OpenAI
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Hugging Face (Optional - for NLP models)
HUGGINGFACE_TOKEN=  # For private models
HUGGINGFACE_CACHE_DIR=/tmp/huggingface_cache

# Local NLP Models
AMHARIC_NLP_MODEL_PATH=/models/amharic-nlp
SPACY_MODEL=en_core_web_sm
LOAD_MODELS_ON_STARTUP=false  # Set to true for faster first request

# ============================================================================
# CELERY (Async Task Queue)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600  # 1 hour max per task
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# Task Queues
CELERY_DEFAULT_QUEUE=default
CELERY_OCR_QUEUE=ocr
CELERY_EXPORT_QUEUE=export
CELERY_PRIORITY_QUEUE=priority

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_CONSOLE=true

# Structured Logging
ENABLE_STRUCTURED_LOGGING=true
LOG_REQUEST_ID=true
LOG_USER_ID=true

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_ENDPOINT=/metrics

# OpenTelemetry Tracing
OPENTELEMETRY_ENABLED=false
OTEL_SERVICE_NAME=amharic-doc-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Health Checks
HEALTH_CHECK_INTERVAL=30  # seconds
ENABLE_DEEP_HEALTH_CHECKS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW=60  # seconds
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STORAGE=redis  # redis or memory

# Per-endpoint limits (requests per minute)
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_SEARCH=30
RATE_LIMIT_EXPORT=20

# ============================================================================
# WEBHOOKS
# ============================================================================
WEBHOOK_TIMEOUT=30  # seconds
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF=2  # exponential backoff multiplier
WEBHOOK_SECRET_HEADER=X-Webhook-Secret

# ============================================================================
# QUALITY ASSURANCE
# ============================================================================
QA_ENABLED=true
QA_MIN_OCR_CONFIDENCE=0.85
QA_CHECK_DOCUMENT_INTEGRITY=true
QA_VALIDATE_AMHARIC_TEXT=true
QA_ANOMALY_DETECTION=true

# SLA Targets
SLA_PROCESSING_TIME_SECONDS=300  # 5 minutes
SLA_SUCCESS_RATE=0.95  # 95%

# ============================================================================
# EXPORT CONFIGURATION
# ============================================================================
EXPORT_TEMP_DIR=/tmp/amharic-exports
EXPORT_MAX_FILE_SIZE=524288000  # 500MB
EXPORT_CLEANUP_INTERVAL=3600  # Clean up temp files every hour
EXPORT_RETENTION_HOURS=24  # Keep exports for 24 hours

# PDF Export
PDF_DPI=300
PDF_QUALITY=95
PDF_COMPRESSION=true

# DOCX Export
DOCX_PAGE_SIZE=A4
DOCX_MARGINS=1.0  # inches

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================
SEARCH_MAX_RESULTS=1000
SEARCH_DEFAULT_PAGE_SIZE=20
SEARCH_HIGHLIGHT_ENABLED=true
SEARCH_FUZZY_ENABLED=true
SEARCH_FUZZY_DISTANCE=2

# Search Suggestions
ENABLE_SEARCH_SUGGESTIONS=true
SEARCH_MIN_QUERY_LENGTH=3
SEARCH_SUGGESTION_LIMIT=10

# ============================================================================
# AUDIT & COMPLIANCE
# ============================================================================
AUDIT_ENABLED=true
AUDIT_LOG_LEVEL=INFO
AUDIT_RETENTION_DAYS=90
AUDIT_LOG_ALL_REQUESTS=false  # Set to true for detailed logging

# Data Retention
DOCUMENT_RETENTION_DAYS=365  # 1 year
JOB_RETENTION_DAYS=30
LOG_RETENTION_DAYS=90

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
# Connection Pooling
DB_POOL_SIZE=20
REDIS_CONNECTION_POOL_SIZE=50

# Caching
ENABLE_CACHE=true
CACHE_TTL=3600  # 1 hour default
CACHE_MAX_SIZE=1000  # MB

# Parallel Processing
MAX_CONCURRENT_JOBS=10
MAX_CONCURRENT_OCR_TASKS=5
BATCH_SIZE=100

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_OCR=true
ENABLE_NLP=true
ENABLE_SUMMARIZATION=true
ENABLE_BATCH_PROCESSING=true
ENABLE_WEBHOOKS=true
ENABLE_EXPORT=true
ENABLE_SEARCH=true
ENABLE_QUALITY_METRICS=true

# Experimental Features
ENABLE_MULTILINGUAL=false
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_AUTO_CLASSIFICATION=false

# ============================================================================
# DEVELOPMENT & DEBUG
# ============================================================================
# Development Tools
ENABLE_SWAGGER_UI=true
ENABLE_REDOC=true
ENABLE_OPENAPI_SCHEMA=true
ENABLE_DEBUG_TOOLBAR=false

# Testing
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres_pass@localhost:5432/amharic_doc_test
TEST_MONGODB_URL=mongodb://admin:mongo_pass@localhost:27017/amharic_documents_test?authSource=admin
PYTEST_TIMEOUT=300

# Debugging
ENABLE_PROFILING=false
PROFILE_OUTPUT_DIR=/tmp/profiling

# ============================================================================
# PRODUCTION OVERRIDES
# ============================================================================
# When ENVIRONMENT=production, ensure:
# - DEBUG=false
# - RELOAD=false
# - DB_ECHO=false
# - MINIO_SECURE=true
# - Strong JWT_SECRET_KEY (32+ characters)
# - Strong passwords for all services
# - CORS_ORIGINS properly configured
# - LOG_LEVEL=WARNING or ERROR
# - Rate limiting enabled
# - All secrets properly secured
